# ------------------------------------------------------------------------------
# -- Database Configuration
# ------------------------------------------------------------------------------
#
# PostgreSQL connection string. Includes the user, password, host, port, and
# database name. Ensure any special characters in the password are URL-encoded.
# Example: postgresql://myuser:mypassword@localhost:5432/cloudbeds_addons
#
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# ------------------------------------------------------------------------------
# -- Authentication Configuration
# ------------------------------------------------------------------------------
#
# A long, secret, and random string used to sign JWTs (JSON Web Tokens).
# A minimum of 32 characters (256 bits) is strongly recommended.
# You can generate a secure one using the commands in `docs/ENVIRONMENT.md`.
#
JWT_SECRET=""

# ------------------------------------------------------------------------------
# -- Cloudbeds API Credentials
# ------------------------------------------------------------------------------
#
# Credentials for the Cloudbeds API v1.2.
# These can be found in your Cloudbeds account under API settings.
#
CLOUDBEDS_API_KEY=""
CLOUDBEDS_PROPERTY_ID=""

# ------------------------------------------------------------------------------
# -- Application Configuration
# ------------------------------------------------------------------------------
#
# The public-facing base URL of the application.
# This is used for generating absolute URLs in the API response.
# For local development, this should be http://localhost:3000.
#
NEXT_PUBLIC_APP_URL="http://localhost:3000"

#
# The directory where custom add-on images will be uploaded.
# This path is relative to the project root. It MUST be inside the `public/`
# directory to be served by Next.js.
#
UPLOAD_DIR="./public/uploads"
